# AI Text Humanizer - Environment Variables Example
# Copy this file to .env and fill in your values if needed

# Ollama Configuration (optional - defaults in config.yaml)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5:14b

# Logging Level (optional)
# LOG_LEVEL=INFO

# Browser Configuration (optional)
# BROWSER_HEADLESS=true

# API Keys (if you add paid detector APIs in the future)
# COPYLEAKS_API_KEY=your_key_here
# ORIGINALITY_API_KEY=your_key_here

# Output Directory (optional)
# OUTPUT_DIR=output

# Note: This file is for future extensibility.
# Currently, all configuration is in config/config.yaml
